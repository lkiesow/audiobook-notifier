# Path to the SQLite database file.
#DATABASE_PATH=data.db

# How often (in hours) to scrape all tracked series in the background.
#SCRAPE_INTERVAL_HOURS=24

# Delay (in seconds) between scraping consecutive series during a scheduled run.
# Keeps request rate low to avoid being rate-limited by Audible.
#SCRAPE_DELAY_SECONDS=60

# Host and port for the Flask web server.
#HOST=127.0.0.1
#PORT=5000

# Python logging level: DEBUG, INFO, WARNING, ERROR
#LOG_LEVEL=INFO

# Matrix notifications (optional — leave all three blank to disable).
# MATRIX_ROOM_ID accepts a room ID (!abc:example.org) or alias (#name:example.org).
# For personal notifications, create a DM room with the bot and use that room ID.
#MATRIX_HOMESERVER=https://matrix.example.org
#MATRIX_ACCESS_TOKEN=your_access_token_here
#MATRIX_ROOM_ID=!yourRoomId:example.org

# Web UI authentication (optional — leave both blank for no login screen).
# When set, all API routes require a valid session cookie.
# Generate a stable SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
# Without SECRET_KEY, an ephemeral key is used and sessions reset on every restart.
#AUTH_USERNAME=admin
#AUTH_PASSWORD=changeme
#SECRET_KEY=

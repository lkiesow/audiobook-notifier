# Path to the SQLite database file.
#DATABASE_PATH=data.db

# How often (in hours) to scrape all tracked series in the background.
#SCRAPE_INTERVAL_HOURS=24

# Delay (in seconds) between scraping consecutive series during a scheduled run.
# Keeps request rate low to avoid being rate-limited by Audible.
#SCRAPE_DELAY_SECONDS=60

# Host and port for the Flask web server.
#HOST=127.0.0.1
#PORT=5000

# Python logging level: DEBUG, INFO, WARNING, ERROR
#LOG_LEVEL=INFO

# Matrix notifications (optional — leave all three blank to disable).
# MATRIX_ROOM_ID accepts a room ID (!abc:example.org) or alias (#name:example.org).
# For personal notifications, create a DM room with the bot and use that room ID.
#MATRIX_HOMESERVER=https://matrix.example.org
#MATRIX_ACCESS_TOKEN=your_access_token_here
#MATRIX_ROOM_ID=!yourRoomId:example.org

# Set to true to also send a Matrix notification when a series scrape fails.
#NOTIFY_SCRAPE_ERRORS=false

# Matrix message type per notification type.
# m.notice = silent bot message (default, suppresses push notifications)
# m.text   = regular message (triggers push notifications like a human message)
#MATRIX_MSGTYPE_NEW_BOOK=m.notice
#MATRIX_MSGTYPE_RELEASING_TODAY=m.notice
#MATRIX_MSGTYPE_SCRAPE_ERROR=m.notice

# Secret key for signing session cookies. Required when using any form of authentication.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# Without SECRET_KEY, an ephemeral key is used and sessions reset on every restart.
#SECRET_KEY=

# Local authentication (optional — leave both blank for no login screen).
# If set, OIDC is ignored.
#AUTH_USERNAME=admin
#AUTH_PASSWORD=changeme

# OpenID Connect login (optional — alternative to local authentication).
# OIDC_ISSUER_URL is the provider's base URL:
#   Authentik:  https://auth.example.com/application/o/myapp
#   Keycloak:   https://auth.example.com/realms/myrealm
#   Google:     https://accounts.google.com
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#OIDC_ISSUER_URL=
#OIDC_REDIRECT_URI=http(s)://your-host/auth/oidc/callback
